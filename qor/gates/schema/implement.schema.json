{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qor-logic.mythologiq/schemas/gates/implement.schema.json",
  "title": "Implement Gate Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["phase", "ts", "session_id", "files_touched"],
  "properties": {
    "phase": { "const": "implement" },
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "session_id": { "type": "string", "minLength": 3 },
    "files_touched": { "type": "array", "items": { "type": "string" } },
    "commits": { "type": "array", "items": { "type": "string" } },
    "test_summary": {
      "type": "object",
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 }
      }
    },
    "ai_provenance": { "$ref": "_provenance.schema.json" }
  }
}
