{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qor-logic.mythologiq/schemas/gates/plan.schema.json",
  "title": "Plan Gate Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["phase", "ts", "session_id", "plan_path", "phases", "ci_commands"],
  "properties": {
    "phase": { "const": "plan" },
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "session_id": { "type": "string", "minLength": 3 },
    "plan_path": { "type": "string", "minLength": 1 },
    "phases": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "ci_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Phase 38 B22: commands the operator runs locally to validate the plan before substantiate. Must match CI for deterministic parity. Required from Phase 38 forward; earlier plans grandfathered at test layer."
    },
    "open_questions": { "type": "array", "items": { "type": "string" } },
    "doc_tier": { "enum": ["minimal", "standard", "system", "legacy"] },
    "doc_tier_rationale": { "type": "string", "minLength": 1 },
    "terms": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["term", "home"],
        "properties": {
          "term": { "type": "string", "minLength": 1 },
          "home": { "type": "string", "minLength": 1 }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "properties": {
        "limitations": { "type": "array", "items": { "type": "string" } },
        "non_goals":   { "type": "array", "items": { "type": "string" } },
        "exclusions":  { "type": "array", "items": { "type": "string" } }
      }
    },
    "high_risk_target": {
      "type": "boolean",
      "description": "Phase 54: declare whether the downstream system being supported by this Qor-logic invocation is itself a high-risk AI system per EU AI Act Annex III. Default false; when true, impact_assessment is required."
    },
    "impact_assessment": {
      "type": "object",
      "description": "Phase 54: optional NIST AI RMF MAP-3.1/MAP-5.1 + EU AI Act Art. 9 risk-register block. Required when high_risk_target is true.",
      "required": ["purpose", "affected_stakeholders", "identified_risks", "mitigations", "residual_risks"],
      "properties": {
        "purpose": { "type": "string", "minLength": 1 },
        "affected_stakeholders": { "type": "array", "items": { "type": "string" } },
        "identified_risks": { "type": "array", "items": { "type": "string" } },
        "mitigations": { "type": "array", "items": { "type": "string" } },
        "residual_risks": { "type": "array", "items": { "type": "string" } }
      }
    },
    "ai_provenance": { "$ref": "_provenance.schema.json" }
  },
  "allOf": [
    {
      "if": { "properties": { "doc_tier": { "const": "legacy" } }, "required": ["doc_tier"] },
      "then": { "required": ["doc_tier_rationale"] }
    },
    {
      "if": { "properties": { "high_risk_target": { "const": true } }, "required": ["high_risk_target"] },
      "then": { "required": ["impact_assessment"] }
    }
  ]
}
