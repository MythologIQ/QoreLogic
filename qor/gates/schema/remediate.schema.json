{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qor-logic.mythologiq/schemas/gates/remediate.schema.json",
  "title": "Remediate Gate Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": ["phase", "ts", "session_id", "events_addressed", "proposed_changes"],
  "properties": {
    "phase": { "const": "remediate" },
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "session_id": { "type": "string", "minLength": 3 },
    "events_addressed": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
    },
    "proposed_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "change"],
        "properties": {
          "target": { "type": "string" },
          "change": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    }
  }
}
