{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://qor-logic.mythologiq/schemas/gates/ideation.schema.json",
  "title": "Ideation Gate Artifact",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "phase", "ts", "session_id", "concept_name",
    "spark", "problem_frame", "transformation_statement",
    "boundaries", "governance_profile", "readiness", "ai_provenance"
  ],
  "properties": {
    "phase": { "const": "ideation" },
    "ts": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$" },
    "session_id": { "type": "string", "minLength": 3 },
    "concept_name": { "type": "string", "minLength": 1 },
    "spark": {
      "type": "object",
      "required": ["observation", "initial_question", "why_now"],
      "properties": {
        "observation": { "type": "string", "minLength": 1 },
        "initial_question": { "type": "string", "minLength": 1 },
        "why_now": { "type": "string", "minLength": 1 }
      }
    },
    "problem_frame": {
      "type": "object",
      "required": ["affected_actors", "failure_mode", "cost_of_failure"],
      "properties": {
        "affected_actors": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "failure_mode": { "type": "string", "minLength": 1 },
        "cost_of_failure": { "type": "string", "minLength": 1 }
      }
    },
    "transformation_statement": { "type": "string", "minLength": 1 },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement", "category", "confidence", "impact_if_wrong"],
        "properties": {
          "statement": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["user", "market", "technical", "workflow",
                     "governance", "operational", "security", "compliance"]
          },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact_if_wrong": { "type": "string", "enum": ["low", "medium", "high"] },
          "validation_method": { "type": "string" },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "boundaries": {
      "type": "object",
      "required": ["non_goals", "limitations", "exclusions"],
      "properties": {
        "non_goals": { "type": "array", "items": { "type": "string" } },
        "limitations": { "type": "array", "items": { "type": "string" } },
        "exclusions": { "type": "array", "items": { "type": "string" } },
        "forbidden_interpretations": { "type": "array", "items": { "type": "string" } }
      }
    },
    "options": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "summary"],
        "properties": {
          "name": { "type": "string" },
          "summary": { "type": "string" },
          "selected": { "type": "boolean" },
          "rejection_reason": { "type": "string" }
        }
      }
    },
    "governance_profile": {
      "type": "object",
      "required": ["risk_grade", "evidence_required"],
      "properties": {
        "risk_grade": { "type": "string", "enum": ["L1", "L2", "L3", "L4"] },
        "evidence_required": { "type": "array", "items": { "type": "string" } },
        "escalation_triggers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "failure_remediation": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["failure_class", "detection_signal", "containment_action", "return_phase"],
        "properties": {
          "failure_class": { "type": "string" },
          "detection_signal": { "type": "string" },
          "containment_action": { "type": "string" },
          "return_phase": {
            "type": "string",
            "enum": ["ideation", "research", "plan", "audit", "implement", "remediate", "substantiate"]
          }
        }
      }
    },
    "readiness": {
      "type": "object",
      "required": ["status", "recommended_next_phase"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "blocked", "research_required", "planning_advisory_only"]
        },
        "blocking_reasons": { "type": "array", "items": { "type": "string" } },
        "recommended_next_phase": {
          "type": "string",
          "enum": ["research", "plan", "hold"]
        }
      }
    },
    "ai_provenance": { "$ref": "_provenance.schema.json" }
  }
}
